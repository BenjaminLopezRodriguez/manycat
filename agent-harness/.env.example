# Any provider supported by LangChain init_chat_model:
# https://python.langchain.com/docs/how_to/chat_models_universal_init/
#
# Examples:
#   MODEL=gpt-4o
#   MODEL=anthropic:claude-sonnet-4-20250514
#   MODEL=ollama:llama3.1
#   MODEL=openai:coder   # Modal open-weight coder (see infra/modal/README.md)
MODEL=gpt-4o

OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# OpenAI-compatible base URL (Modal vLLM). Include /v1.
# OPENAI_BASE_URL=https://YOUR-MODAL-URL/v1

# Per-request effort is sent by the UI (low|medium|high|max) and overrides
# temperature / max_tokens / turn limits on each /run.

# Workspace root the agent may read/write (defaults to cwd)
WORKSPACE_ROOT=

# Website verification tools (browser_check / read_app_logs / report_to_evaluator)
# MODAL_EVAL_URL=https://YOUR-WORKSPACE--openweight-eval-serve.modal.run/v1
# EVAL_MODEL_NAME=eval
# SANDBOX_ORCHESTRATOR_URL=http://localhost:8080
# PREVIEW_URL_HOST_REWRITE=host.docker.internal
